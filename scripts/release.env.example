# Copy this file to scripts/release.env and fill in local Apple Developer values.
# scripts/release.env is intentionally ignored by git.

# Required for Developer ID export/signing.
# Example: ABCDE12345
KNOWLEDGED_MAC_TEAM_ID=

# Optional. If omitted, Xcode uses "Developer ID Application".
# Example: Developer ID Application: Your Name (ABCDE12345)
KNOWLEDGED_MAC_SIGNING_CERTIFICATE=

# Required for notarization. Create once with:
# xcrun notarytool store-credentials "knowledged-mac-notary" --apple-id "you@example.com" --team-id "ABCDE12345" --password "app-specific-password"
KNOWLEDGED_MAC_NOTARY_PROFILE=knowledged-mac-notary

# Optional build customization.
# KNOWLEDGED_MAC_BUNDLE_ID=com.wiztools.KnowledgedMac
# KNOWLEDGED_MAC_VERSION=1.0
# KNOWLEDGED_MAC_BUILD=1
